
with flat_table as (
select a.machine_id , a.process_id , a.activity_type, a.timestamp as start_time,
        a1.timestamp as end_time
from 
    Activity a 
join Activity a1
on a.process_id = a1.process_id and a.machine_id = a1.machine_id
where 
    a.activity_type = 'start' and a1.activity_type = 'end'
)

select machine_id , round(sum((end_time - start_time))/count(*) ,3) as processing_time
from flat_table
group by machine_id
